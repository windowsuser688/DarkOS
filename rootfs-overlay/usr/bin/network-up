#!/bin/sh
set -u

PATH=/sbin:/bin:/usr/sbin:/usr/bin
export PATH

log() {
	printf '%s\n' "network-up: $*" >/dev/console 2>/dev/null || printf '%s\n' "network-up: $*"
}

is_mounted() {
	awk -v dir="$1" '$2 == dir { found = 1 } END { exit found ? 0 : 1 }' /proc/mounts 2>/dev/null
}

ensure_tmpfs() {
	dir=$1
	mode=$2
	mkdir -p "$dir" 2>/dev/null || true
	if ! is_mounted "$dir"; then
		mount -t tmpfs tmpfs "$dir" 2>/dev/null || true
	fi
	chmod "$mode" "$dir" 2>/dev/null || true
}

find_iface() {
	for path in /sys/class/net/*; do
		[ -e "$path" ] || continue
		iface=${path##*/}
		[ "$iface" = lo ] && continue
		# Skip Wi-Fi interfaces — NetworkManager owns those
		[ -e "/sys/class/net/$iface/wireless" ] && continue
		printf '%s\n' "$iface"
		return 0
	done
	return 1
}

load_modules() {
	for module in \
		mii libphy fixed_phy mdio_devres \
		virtio_net e100 e1000 e1000e igb igbvf igc ixgbe ixgbevf \
		8139too 8139cp r8169 atlantic alx atl1 atl1c atl1e atl2 \
		tg3 b44 bnx2 bnx2x bnxt_en forcedeth pcnet32 ne2k_pci vmxnet3 \
		hv_netvsc ena gve mlx4_en mlx5_core \
		usbnet cdc_ether cdc_ncm cdc_eem cdc_mbim rndis_host \
		asix ax88179_178a dm9601 pegasus rtl8150 r8152 kalmia \
		cfg80211 mac80211 rfkill iwlwifi iwldvm iwlmvm ath ath5k ath9k \
		ath9k_htc ath10k_core ath10k_pci ath11k ath11k_pci ath12k \
		rtlwifi rtl8192cu rtw88_core rtw88_pci rtw88_usb rtw89_core \
		rtw89_pci brcmutil brcmfmac brcmsmac mt76 mt76_usb mt76x0u \
		mt76x2u mt7601u mt7921e mt7921u mt7925e mt7925u mwifiex \
		mwifiex_pcie mwifiex_sdio
	do
		modprobe -q "$module" 2>/dev/null || true
	done
}

iface=${1:-}
[ "$iface" = "--boot" ] && iface=

ensure_tmpfs /var/lib/dhcpcd 0755
mkdir -p /run/dhcpcd /run/resolvconf /run/resolvconf/interfaces 2>/dev/null || true
if [ ! -f /run/resolv.conf ]; then
	cat > /run/resolv.conf <<'EOF' 2>/dev/null || true
# Generated by resolvconf
nameserver 10.0.2.3
nameserver 1.1.1.1
nameserver 8.8.8.8
EOF
fi

log "loading network drivers"
load_modules

if [ -x /bin/udevadm ]; then
	/bin/udevadm trigger --subsystem-match=net --action=add 2>/dev/null || true
	/bin/udevadm settle --timeout=5 2>/dev/null || true
fi

# If NetworkManager is present it will manage all interfaces (including Wi-Fi).
# Only use dhcpcd here as a fallback for wired interfaces on systems without NM.
if [ -x /usr/sbin/NetworkManager ]; then
	log "NetworkManager present — skipping dhcpcd, NM will manage interfaces"
	ip link set lo up 2>/dev/null || true
	exit 0
fi

i=0
while [ -z "$iface" ] && [ "$i" -lt 50 ]; do
	iface=$(find_iface 2>/dev/null || true)
	[ -n "$iface" ] && break
	i=$((i + 1))
	sleep 0.1
done

if [ -z "$iface" ]; then
	log "no network interface found"
	exit 1
fi

log "using $iface"
ip link set lo up 2>/dev/null || true
ip link set "$iface" up 2>/dev/null || true

if command -v dhcpcd >/dev/null 2>&1; then
	if dhcpcd -q -4 -w -t 20 "$iface"; then
		log "DHCP complete on $iface"
	else
		log "DHCP did not complete on $iface"
	fi
else
	log "dhcpcd is missing"
	exit 1
fi

ip -4 addr show dev "$iface" 2>/dev/null | sed 's/^/network-up: /' >/dev/console 2>/dev/null || true
ip route show 2>/dev/null | sed 's/^/network-up: route /' >/dev/console 2>/dev/null || true
