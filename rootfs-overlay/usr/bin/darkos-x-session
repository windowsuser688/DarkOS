#!/bin/sh
set -eu

export HOME=/root
export USER=root
export LOGNAME=root
export SHELL=/bin/sh
export LANG="${LANG:-en_US.UTF-8}"
export LC_CTYPE="${LC_CTYPE:-en_US.UTF-8}"
export BROWSER=chromium
export XDG_RUNTIME_DIR=/run/user/0
export XDG_CACHE_HOME=/root/.cache
export XDG_CONFIG_HOME=/root/.config
export XDG_DATA_HOME=/root/.local/share
export GDK_BACKEND=x11,wayland
export GDK_GL=disable
export LIBGL_ALWAYS_SOFTWARE=0
export WEBKIT_DISABLE_COMPOSITING_MODE=1
export WEBKIT_DISABLE_DMABUF_RENDERER=1
export WEBKIT_WEBGL_DISABLE_GBM=1
export MESA_SHADER_CACHE_DIR=/root/.cache/mesa

if ! touch /root/.darkos-write-test 2>/dev/null; then
	mount -t tmpfs tmpfs /root 2>/dev/null || true
fi
rm -f /root/.darkos-write-test 2>/dev/null || true

mkdir -p /run/user/0 /tmp/.X11-unix /root/.cache /root/.cache/mesa \
	/root/.config /root/.local/share /root/.mozilla
chmod 700 /run/user/0
chmod 700 /root /root/.cache /root/.cache/mesa /root/.config /root/.local \
	/root/.local/share /root/.mozilla
chmod 1777 /tmp/.X11-unix

xconf=$(/usr/bin/darkos-x-config)

exec xinit /etc/X11/xinit/xinitrc -- /usr/bin/Xorg :0 vt7 -nolisten tcp -config "$xconf" -configdir /run/darkos/xorg.conf.d -logfile /tmp/Xorg.0.log
